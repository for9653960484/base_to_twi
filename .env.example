# === Локальная разработка ===
# Скопируйте в .env и настройте. PostgreSQL и Redis — на localhost (не Docker).
# Подробно: docs/local-development.md
APP_NAME=base_to
APP_ENV=development
APP_SECRET_KEY=change-me-in-production

# === PostgreSQL ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=base_to
POSTGRES_USER=base_to
POSTGRES_PASSWORD=base_to_secret

# === Redis (очереди AI) ===
REDIS_URL=redis://localhost:6379/0

# === Backend API ===
API_HOST=0.0.0.0
API_PORT=8000
API_VERSION=v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# === JWT / Auth ===
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# === File storage ===
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=storage
STORAGE_S3_BUCKET=
STORAGE_S3_ENDPOINT=
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=

# === AI Service (URL для backend) ===
AI_SERVICE_URL=http://localhost:8001
AI_CALLBACK_SECRET=change-me-callback-secret

# === AI Provider (external | local | hybrid) ===
AI_PROVIDER=hybrid

# --- Внешний API (OpenAI-совместимый) ---
AI_EXTERNAL_API_KEY=
AI_EXTERNAL_BASE_URL=https://api.openai.com/v1
# Тяжёлая LLM: анализ документации, генерация инструкций/TWI
AI_EXTERNAL_MODEL=gpt-4o
# Лёгкая LLM: рутинные тексты, подсказки
AI_LIGHT_MODEL=gpt-4o-mini

# --- Локальный сервер (Ollama / vLLM) ---
AI_LOCAL_BASE_URL=http://localhost:11434
AI_LOCAL_HEAVY_MODEL=llama3.1:70b
AI_LOCAL_LIGHT_MODEL=llama3:8b

# --- Embeddings (векторизация для базы знаний) ---
# provider: external | local
AI_EMBEDDING_PROVIDER=external
AI_EMBEDDING_MODEL=text-embedding-3-small
# Пусто = использовать AI_EXTERNAL_BASE_URL / AI_EXTERNAL_API_KEY
AI_EMBEDDING_BASE_URL=
AI_EMBEDDING_API_KEY=
# Локальная модель эмбеддингов (Ollama: nomic-embed-text и т.п.)
AI_EMBEDDING_LOCAL_MODEL=nomic-embed-text

# --- Q&A поиск по базе знаний ---
AI_QA_MODEL=
# Пусто = AI_EXTERNAL_MODEL (тяжёлая модель)

# --- Размерность векторов (должна совпадать с моделью эмбеддингов) ---
VECTOR_DIMENSION=1536

# === HR Integration ===
HR_API_URL=
HR_API_KEY=
HR_SYNC_CRON=0 2 * * *

# === Frontend ===
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_DEFAULT_LOCALE=ru
